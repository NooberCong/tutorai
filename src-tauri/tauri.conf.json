{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TutorAI",
  "version": "0.1.0",
  "identifier": "com.tutorai.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TutorAI",
        "backgroundColor": "#090d0b",
        "width": 1440,
        "height": 920,
        "minWidth": 980,
        "minHeight": 620,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
